# Database Configuration
# For local PostgreSQL: postgresql://username@localhost:5432/database_name
# For remote: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://dev@localhost:5432/mendly

# Session Secret (Generate a random 32+ character string)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-secret-key-here-minimum-32-characters

# JWT Secret for mobile authentication (optional, defaults to SESSION_SECRET)
# JWT_SECRET=your-jwt-secret-here-minimum-32-characters

# Server Port
PORT=5055

# Node Environment
NODE_ENV=development

# ========== CORS CONFIGURATION ==========
# Comma-separated list of allowed origins for production
# Mobile apps don't send origin headers, so they're always allowed
# CORS_ORIGINS=https://khunjit.com,https://www.khunjit.com

# Replit Auth (Only needed on Replit)
# REPL_ID=
# ISSUER_URL=https://replit.com/oidc

# ========== EMAIL CONFIGURATION ==========
# Email system supports 11 languages: de, en, fil, fr, id, it, ja, ko, th, tr, vi
# Emails are sent in user's preferred language automatically

# ========== RESEND (RECOMMENDED - PRIMARY) ==========
# Modern email API with generous free tier
# Sign up: https://resend.com/signup
# Free tier: 100 emails/day, 3000 emails in first month
# Setup:
#   1. Create account at https://resend.com
#   2. Add and verify your domain (or use resend.dev for testing)
#   3. Create API key at https://resend.com/api-keys
#   4. Add key below

# Resend API Key
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# From address (must be from verified domain)
# For testing, use: onboarding@resend.dev
# For production: noreply@khunjit.com
# EMAIL_FROM=KhunJit <noreply@khunjit.com>

# ========== SMTP (FALLBACK - OPTIONAL) ==========
# If Resend fails, system falls back to SMTP
# You can use only SMTP if you prefer (without Resend)

# SMTP Host (e.g., smtp.gmail.com, khunjit.com, smtp-relay.brevo.com)
# SMTP_HOST=khunjit.com

# SMTP Port (587 for TLS, 465 for SSL)
# SMTP_PORT=465

# Set to "true" for port 465 (SSL), "false" for port 587 (TLS)
# SMTP_SECURE=true

# SMTP Username (usually your email address)
# SMTP_USER=support@khunjit.com

# SMTP Password or App Password
# For Gmail: Use App Password (https://myaccount.google.com/apppasswords)
# For cPanel/DirectAdmin: Use email account password
# For Brevo/Mailjet: Use API Key
# SMTP_PASS=your-smtp-password

# From address for SMTP (if different from EMAIL_FROM)
# SMTP_FROM=KhunJit <support@khunjit.com>

# ========== GENERAL EMAIL SETTINGS ==========
# Platform URL (used in email links - dashboard, video call, etc.)
# PLATFORM_URL=https://khunjit.com

# ========== FREE SMTP OPTIONS ==========
#
# 1. Gmail (500 emails/day for personal, requires App Password)
#    SMTP_HOST=smtp.gmail.com
#    SMTP_PORT=587
#    SMTP_SECURE=false
#
# 2. Brevo (formerly Sendinblue) - 300 emails/day free
#    SMTP_HOST=smtp-relay.brevo.com
#    SMTP_PORT=587
#    SMTP_SECURE=false
#
# 3. Mailjet - 200 emails/day free
#    SMTP_HOST=in-v3.mailjet.com
#    SMTP_PORT=587
#    SMTP_SECURE=false
#
# 4. Mailtrap (for testing only)
#    SMTP_HOST=sandbox.smtp.mailtrap.io
#    SMTP_PORT=2525

# ========== PAYMENT CONFIGURATION (Thailand - PromptPay) ==========
# Opn Payments (formerly Omise) - Thailand Payment Gateway
# Sign up at: https://www.opn.ooo/
# Get your keys from: https://dashboard.omise.co/settings/keys

# Public Key (used for client-side tokenization - not needed for QR payments)
# OPN_PUBLIC_KEY=pkey_test_xxxxxxxxxxxxx

# Secret Key (REQUIRED for server-side API calls)
# OPN_SECRET_KEY=skey_test_xxxxxxxxxxxxx

# Webhook Secret (for verifying webhook signatures)
# Get this from: https://dashboard.omise.co/webhooks
# OPN_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# ========== PAYMENT CONFIGURATION (Development Mode) ==========
# If OPN_SECRET_KEY is not set, the system runs in development mode:
# - Real Thai QR codes are generated using PromptPay standard
# - Use /api/payments/:id/simulate-complete (admin only) to simulate payment completion
# - Perfect for local development and testing without real payments

# ========== THAI QR / PROMPTPAY CONFIGURATION ==========
# Used in development mode to generate real Thai QR codes

# Test mode (set to true to always use 1.00 THB for all payments)
# TEST_MODE=true

# PromptPay receiver type: BANK_ACCOUNT or PHONE
# Note: Bank accounts must be registered with PromptPay to work
# If not registered, system will automatically fall back to PHONE
# PROMPTPAY_RECEIVER_TYPE=BANK_ACCOUNT

# KBank account number (if using BANK_ACCOUNT type)
# KBANK_ACCOUNT=0073902908

# PromptPay phone number (primary or fallback)
# Must be 10 digits starting with 0
# PROMPTPAY_PHONE=0908925858

# ========== STRIPE CONNECT CONFIGURATION ==========
# Stripe Connect enables international credit card payments and automatic psychologist payouts
# Sign up at: https://stripe.com/connect
# Get your keys from: https://dashboard.stripe.com/apikeys

# Stripe Secret Key (REQUIRED for Stripe Connect to work)
# Test mode: sk_test_xxxxxxxxxxxxx
# Live mode: sk_live_xxxxxxxxxxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# Stripe Publishable Key (for client-side - not used in backend)
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# Stripe Webhook Secret (for verifying webhook signatures)
# Create webhook at: https://dashboard.stripe.com/webhooks
# Webhook URL: https://khunjit.com/webhooks/stripe
# Events to listen for:
#   - checkout.session.completed (payment success)
#   - checkout.session.expired (payment timeout)
#   - payment_intent.succeeded
#   - payment_intent.payment_failed
#   - charge.refunded
#   - account.updated (Connect onboarding)
#   - capability.updated (Connect)
#   - account.application.deauthorized (Connect disconnect)
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Platform URL (REQUIRED - used for Stripe redirects and email links)
# Must be https in production
# PLATFORM_URL=https://khunjit.com

# Base URL (alias for PLATFORM_URL - used in some legacy code)
# BASE_URL=https://khunjit.com
