# ========== API BASE URL CONFIGURATION ==========
#
# The mobile app connects to the same backend as the web app.
# This URL should point to your running backend server.
#
# IMPORTANT: The backend must be accessible from your device!
#
# ---- Development Options ----
#
# 1. iOS Simulator (macOS):
#    EXPO_PUBLIC_API_BASE_URL=http://localhost:5055
#
# 2. Android Emulator:
#    EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:5055
#    (10.0.2.2 is Android emulator's alias for host machine localhost)
#
# 3. Real Device (same WiFi network):
#    - Find your computer's LAN IP:
#      * macOS: System Preferences > Network, or run: ipconfig getifaddr en0
#      * Windows: ipconfig | findstr IPv4
#      * Linux: hostname -I
#    - Use that IP:
#    EXPO_PUBLIC_API_BASE_URL=http://192.168.1.XXX:5055
#
# ---- Production ----
#
# EXPO_PUBLIC_API_BASE_URL=https://mendly.app
#
# ========================================

# Default: localhost for simulator development
EXPO_PUBLIC_API_BASE_URL=http://localhost:5055
